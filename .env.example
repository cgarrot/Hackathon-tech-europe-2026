LLM_PROVIDER=ollama
LLM_TIMEOUT_MS=180000
GAMEFORGE_RATE_LIMIT_WINDOW_MS=60000
GAMEFORGE_RATE_LIMIT_MAX_REQUESTS=8
GAMEFORGE_MAX_CONCURRENT_REQUESTS=2
GAMEFORGE_VOICE_RATE_LIMIT_WINDOW_MS=60000
GAMEFORGE_VOICE_RATE_LIMIT_MAX_REQUESTS=20
GAMEFORGE_MAX_CONCURRENT_VOICE_REQUESTS=4
FAL_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional proxy/custom OpenAI-compatible base URL for the OpenAI provider.
OPENAI_BASE_URL=

OLLAMA_API_KEY=
# Ollama's OpenAI-compatible endpoint. Native cloud API is https://ollama.com/api.
OLLAMA_BASE_URL=https://ollama.com/v1/
OLLAMA_MODEL=deepseek-v4-flash

# Gradium voice runtime. Keep API keys server-side only; never expose them in generated projects.
GRADIUM_API_KEY=
GRADIUM_BASE_URL=https://api.gradium.ai/api
GRADIUM_LANGUAGE=fr
GRADIUM_FR_VOICE_ID=
GRADIUM_EN_VOICE_ID=
# Optional. If empty, GameForge uses Gradium's documented quickstart voice id.
GRADIUM_DEFAULT_VOICE_ID=YTpq7expH9539ERJ
GRADIUM_TIMEOUT_MS=60000
