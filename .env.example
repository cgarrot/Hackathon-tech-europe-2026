LLM_PROVIDER=ollama
LLM_TIMEOUT_MS=180000
GAMEFORGE_RATE_LIMIT_WINDOW_MS=60000
GAMEFORGE_RATE_LIMIT_MAX_REQUESTS=8
GAMEFORGE_MAX_CONCURRENT_REQUESTS=2
GAMEFORGE_VOICE_RATE_LIMIT_WINDOW_MS=60000
GAMEFORGE_VOICE_RATE_LIMIT_MAX_REQUESTS=20
GAMEFORGE_MAX_CONCURRENT_VOICE_REQUESTS=4

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional proxy/custom OpenAI-compatible base URL for the OpenAI provider.
OPENAI_BASE_URL=

# Pioneer's OpenAI-compatible endpoint. Defaults in code are shown here for clarity.
PIONEER_API_KEY=
PIONEER_BASE_URL=https://api.pioneer.ai/v1
PIONEER_MODEL=moonshotai/Kimi-K2.6
PIONEER_MAX_TOKENS=7000

# Optional fail-open Pioneer/Kimi complement.
# Keep the main compiler provider as OpenAI/Ollama/etc., then let Pioneer only refine
# visual image prompts and persona sampleLines for Gradium TTS text.
PIONEER_ARTIFACT_ENHANCEMENT=false
PIONEER_ARTIFACT_API_KEY=
PIONEER_ARTIFACT_BASE_URL=https://api.pioneer.ai/v1
PIONEER_ARTIFACT_MODEL=moonshotai/Kimi-K2.6
PIONEER_ARTIFACT_MAX_TOKENS=2000
PIONEER_ARTIFACT_TIMEOUT_MS=45000
# Optional: use the fine-tuned Pioneer artifact model first for this complement.
# If it fails or is not served, GameForge falls back to Pioneer/Kimi serverless above.
PIONEER_ARTIFACT_FINE_TUNE_MODEL_ID=
PIONEER_ARTIFACT_FINE_TUNE_API_KEY=
PIONEER_ARTIFACT_FINE_TUNE_ENDPOINT=https://api.pioneer.ai/inference
PIONEER_ARTIFACT_FINE_TUNE_TIMEOUT_MS=45000

# Optional upstream GLiNER extraction before the compiler LLM stages.
# Leave PIONEER_GLINER_MODEL_ID empty to skip this fail-open step.
PIONEER_GLINER_MODEL_ID=
PIONEER_GLINER_ENDPOINT=https://api.pioneer.ai/inference
PIONEER_GLINER_LABELS=game_type,setting,player_count,ai_count,role,mechanic
PIONEER_GLINER_THRESHOLD=0.45
PIONEER_GLINER_TIMEOUT_MS=8000

OLLAMA_API_KEY=
# Ollama's OpenAI-compatible endpoint. Native cloud API is https://ollama.com/api.
OLLAMA_BASE_URL=https://ollama.com/v1/
OLLAMA_MODEL=deepseek-v4-flash

# Gradium voice runtime. Keep API keys server-side only; never expose them in generated projects.
GRADIUM_API_KEY=
GRADIUM_BASE_URL=https://api.gradium.ai/api
GRADIUM_LANGUAGE=fr
GRADIUM_FR_VOICE_ID=
GRADIUM_EN_VOICE_ID=
# Optional. If empty, GameForge uses Gradium's documented quickstart voice id.
GRADIUM_DEFAULT_VOICE_ID=YTpq7expH9539ERJ
GRADIUM_TIMEOUT_MS=60000
